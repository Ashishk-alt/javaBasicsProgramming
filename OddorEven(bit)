public class BitManipulation{
    public static void oddOrEven(int n){
        int bitMask = 1;
        if((n & bitMask) == 0){
            System.out.println("Even N0.");
        }else{
            System.out.println("Odd N0.");
        }
    }
    public static void main(String args[]){
        oddOrEven(5);
        oddOrEven(8);
    }
}
