public class OOPS{
    public static void main(String args[]){
        Pen p1 = new Pen(); //created an pen object called P1
        p1.setColor("Blue");
        System.out.println(p1.color);

        p1.setTip(5);
        System.out.println(p1.tip);
    }
}
class Pen{
    String color;
    int tip;
    
    //function to property color of class pen
    void setColor(String newColor){
        color= newColor;
    }
    
    //function to property tip of class pen
    void setTip(int newTip){
        tip = newTip;
    }
}
